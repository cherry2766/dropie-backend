# --- Spring Profile ---
# local: 로컬 개발 (application-local.yml 적용)
# prod : 운영 (application-prod.yml 적용) ← EC2에서 사용
SPRING_PROFILES_ACTIVE=local


# --- Database (MySQL) ---
# 로컬: docker-compose의 mysql 서비스명 사용 → DB_HOST=mysql
# 운영: RDS 엔드포인트 → DB_HOST=dropie-db.xxxxx.ap-northeast-2.rds.amazonaws.com
DB_HOST=mysql
DB_PORT=3306
DB_NAME=dropie
DB_USERNAME=dropie_user
DB_PASSWORD=CHANGE_ME


# --- Redis ---
# 로컬: docker-compose의 redis 서비스명 사용 → REDIS_HOST=redis
# 운영(EC2 단일 인스턴스 + docker-compose): REDIS_HOST=redis (같음)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=


# --- JWT ---
# 256bit 이상 권장. 생성 방법: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING_256BIT_MINIMUM


# --- Mail (Gmail SMTP) ---
# Gmail 앱 비밀번호 (2단계 인증 후 발급, 일반 비밀번호 아님)
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD


# --- AWS S3 ---
# IAM 사용자 발급 키. 절대 GitHub에 커밋 금지.
AWS_ACCESS_KEY=CHANGE_ME
AWS_SECRET_KEY=CHANGE_ME
AWS_S3_BUCKET=dropie-bucket-s3
AWS_S3_REGION=ap-northeast-2


# --- Admin 초기 계정 ---
# 앱 최초 실행 시 DataInitializer가 자동 생성
ADMIN_EMAIL=admin@dropie.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NICKNAME=admin


# --- Toss Payments ---
# 테스트 키는 토스 개발자 콘솔에서 발급
# https://developers.tosspayments.com/
TOSS_SECRET_KEY=test_sk_CHANGE_ME
TOSS_CLIENT_KEY=test_ck_CHANGE_ME


# --- Claude API (Anthropic) ---
CLAUDE_API_KEY=CHANGE_ME
# 아래 두 줄은 application.yml에 기본값 있어서 미작성 OK
# CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_MODEL=claude-haiku-4-5-20251001


# --- CORS ---
# 로컬: http://localhost:5173
# 운영: 프론트 도메인 (예: https://dropie.shop)
# 여러 개는 콤마로: http://localhost:5173,https://dropie.shop
CORS_ALLOWED_ORIGINS=http://localhost:5173


# --- 인증 메일 URL ---
# APP_BASE_URL: 인증 메일 링크의 백엔드 주소 (사용자가 클릭 → /auth/verify-email 호출)
#   로컬: http://localhost:8080 / 운영: 백엔드 도메인 (예: https://api.dropie.shop)
# APP_FRONTEND_URL: 인증 처리 후 이동할 프론트 주소 (/signup-complete)
#   로컬: http://localhost:5173 / 운영: 프론트 도메인 (예: https://dropie.shop)
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:5173